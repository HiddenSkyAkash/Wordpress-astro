{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/our-clients/?$",
			"dest": "_render"
		},
		{
			"src": "^/services/?$",
			"dest": "_render"
		},
		{
			"src": "^/solutions/business-process-automation/?$",
			"dest": "_render"
		},
		{
			"src": "^/solutions/crm-development/?$",
			"dest": "_render"
		},
		{
			"src": "^/solutions/custom-business-dashboards/?$",
			"dest": "_render"
		},
		{
			"src": "^/solutions/digital-transformation/?$",
			"dest": "_render"
		},
		{
			"src": "^/solutions/sales-lead-tracking-tools/?$",
			"dest": "_render"
		},
		{
			"src": "^/solutions/technology-consulting/?$",
			"dest": "_render"
		},
		{
			"src": "^/solutions/workflow-automation-solutions/?$",
			"dest": "_render"
		},
		{
			"src": "^/tag/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}