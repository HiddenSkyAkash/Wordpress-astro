---
import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;

// Fetch post from WP API
const res = await fetch(`https://demskigroup.com/wp-json/wp/v2/posts?_embed&slug=${slug}`);
const posts = await res.json();
const post = posts[0];

if (!post) {
  return Astro.redirect('/blog');
}

const title = post.title?.rendered ?? '';
const content = post.content?.rendered ?? '';
const date = new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const img = post._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? '';
const imgAlt = post._embedded?.['wp:featuredmedia']?.[0]?.alt_text ?? title;
const author = post._embedded?.['author']?.[0]?.name ?? '';
const cats = post._embedded?.['wp:term']?.[0] ?? [];

// Sidebar: recent posts
const recentRes = await fetch('https://demskigroup.com/wp-json/wp/v2/posts?_embed&per_page=5');
const recentPosts = await recentRes.json();

// Sidebar: categories
const catRes = await fetch('https://demskigroup.com/wp-json/wp/v2/categories?per_page=20&hide_empty=true');
const categories = await catRes.json();

// Sidebar: tags
const tagRes = await fetch('https://demskigroup.com/wp-json/wp/v2/tags?per_page=50&orderby=name&order=asc');
const tags = await tagRes.json();
---

<Layout title={`${title} - The Demski Group`} description={post.excerpt?.rendered?.replace(/<[^>]+>/g,'').substring(0,160)}>

  <style slot="head">
    /* ── SINGLE POST PAGE ── */
    .post-page { font-family: 'Outfit', sans-serif; color: #282828; }

    /* Hero breadcrumb */
    .post-breadcrumb {
      background: #faf9f5;
      padding: 30px 60px 20px;
      font-size: 14px;
      color: #888;
    }
    .post-breadcrumb a { color: #888; text-decoration: none; }
    .post-breadcrumb a:hover { color: #003087; }
    .post-breadcrumb span { margin: 0 6px; }

    /* Title section */
    .post-title-section {
      background: #faf9f5;
      padding: 10px 60px 40px;
      max-width: 900px;
    }
    .post-title-section h1 {
      font-size: clamp(28px, 3.5vw, 48px);
      font-weight: 800;
      color: #0A0000;
      line-height: 1.15;
      margin: 0;
    }

    /* Main layout */
    .post-body-wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding: 40px 60px 80px;
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 60px;
      align-items: flex-start;
    }

    /* Article */
    .post-article { min-width: 0; }

    /* Featured image */
    .post-featured-img {
      width: 100%;
      max-height: 500px;
      object-fit: cover;
      border-radius: 8px;
      display: block;
      margin-bottom: 28px;
    }

    /* Post meta */
    .post-meta {
      display: flex;
      align-items: center;
      gap: 18px;
      flex-wrap: wrap;
      margin-bottom: 28px;
      font-size: 15px;
      color: #888;
    }
    .post-meta-item { display: flex; align-items: center; gap: 6px; }
    .post-meta-item svg { flex-shrink: 0; }
    .post-cat-tag {
      border: 1px solid #ccc; color: #555; padding: 2px 12px;
      border-radius: 20px; font-size: 14px; text-decoration: none;
      transition: all 0.2s;
    }
    .post-cat-tag:hover { background: #003087; color: #fff; border-color: #003087; }

    /* Post content */
    .post-content-body {
      font-size: 17px;
      line-height: 1.8;
      color: #333;
    }
    .post-content-body h1,
    .post-content-body h2,
    .post-content-body h3,
    .post-content-body h4 {
      font-family: 'Outfit', sans-serif;
      color: #0A0000;
      margin: 36px 0 14px;
      line-height: 1.3;
    }
    .post-content-body h2 { font-size: 26px; font-weight: 700; }
    .post-content-body h3 { font-size: 22px; font-weight: 700; }
    .post-content-body h4 { font-size: 18px; font-weight: 700; }
    .post-content-body p { margin: 0 0 20px; }
    .post-content-body ul,
    .post-content-body ol { margin: 0 0 20px 24px; }
    .post-content-body li { margin-bottom: 8px; }
    .post-content-body img {
      max-width: 100%; height: auto;
      border-radius: 8px; margin: 24px 0; display: block;
    }
    .post-content-body a { color: #003087; text-decoration: underline; }
    .post-content-body a:hover { color: #0154b1; }
    .post-content-body blockquote {
      border-left: 4px solid #003087;
      padding: 16px 24px;
      margin: 24px 0;
      background: #f5f8ff;
      border-radius: 0 8px 8px 0;
      font-style: italic;
      color: #555;
    }
    .post-content-body strong { color: #0A0000; font-weight: 700; }
    .post-content-body table { width: 100%; border-collapse: collapse; margin: 24px 0; font-size: 15px; }
    .post-content-body th { background: #0A0000; color: #fff; padding: 12px 16px; text-align: left; }
    .post-content-body td { padding: 10px 16px; border-bottom: 1px solid #eee; }
    .post-content-body tr:nth-child(even) td { background: #f9f9f9; }

    /* CTA banner inside post */
    .post-cta-banner {
      background: #0A0000;
      border-radius: 16px;
      padding: 36px 40px;
      margin: 40px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      flex-wrap: wrap;
    }
    .post-cta-banner-img {
      width: 180px; height: 120px;
      object-fit: cover; border-radius: 10px; flex-shrink: 0;
    }
    .post-cta-text { flex: 1; }
    .post-cta-text p { color: #fff; font-size: 20px; font-weight: 600; margin: 0 0 16px; line-height: 1.4; }
    .post-cta-text a {
      display: inline-flex; align-items: center; gap: 8px;
      background: #f09300; color: #fff;
      padding: 12px 24px; border-radius: 8px;
      font-size: 16px; font-weight: 600; text-decoration: none;
      transition: background 0.2s;
    }
    .post-cta-text a:hover { background: #d98200; }

    /* Post footer */
    .post-footer {
      margin-top: 48px;
      padding-top: 28px;
      border-top: 1px solid #eee;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    .post-back-link {
      display: inline-flex; align-items: center; gap: 8px;
      color: #003087; font-weight: 600; font-size: 15px; text-decoration: none;
    }
    .post-back-link:hover { text-decoration: underline; }

    /* ── SIDEBAR ── */
    .post-sidebar { position: sticky; top: 100px; }
    .sb-box {
      background: #faf9f5; border: 1px solid #ebebeb;
      border-radius: 8px; padding: 22px; margin-bottom: 24px;
    }
    .sb-box h3 {
      font-size: 17px; font-weight: 700; color: #0A0000;
      border-bottom: 2px solid #0A0000; padding-bottom: 8px; margin-bottom: 16px;
      display: inline-block;
    }

    /* Search */
    .sb-search {
      display: flex; align-items: center;
      border: 1.5px solid #e0e0e0; border-radius: 50px;
      overflow: hidden; background: #fff; padding: 6px 16px; gap: 8px;
    }
    .sb-search input {
      border: none; outline: none; font-size: 15px;
      width: 100%; font-family: 'Outfit', sans-serif;
      background: transparent; color: #333;
    }
    .sb-search input::placeholder { color: #aaa; }

    /* Recent posts */
    .sb-recent-list { list-style: none; margin: 0; padding: 0; }
    .sb-recent-list li { padding: 12px 0; border-bottom: 1px solid #f0f0f0; }
    .sb-recent-list li:last-child { border-bottom: none; }
    .sb-recent-list a { font-size: 14px; color: #333; text-decoration: none; line-height: 1.5; display: block; }
    .sb-recent-list a:hover { color: #003087; }

    /* Categories */
    .sb-cat-list { list-style: none; margin: 0; padding: 0; }
    .sb-cat-list li { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #eee; font-size: 15px; }
    .sb-cat-list li:last-child { border-bottom: none; }
    .sb-cat-list a { color: #333; text-decoration: none; }
    .sb-cat-list a:hover { color: #003087; }
    .sb-cat-list span { color: #aaa; font-size: 13px; }

    /* Tag cloud */
    .sb-tag-cloud { display: flex; flex-wrap: wrap; gap: 8px; }
    .sb-tag { font-size: 13px; color: #333; background: #e2e2e2; padding: 6px 14px; border-radius: 20px; text-decoration: none; transition: all 0.2s; }
    .sb-tag:hover { background: #000; color: #fff; }

    /* Responsive */
    @media (max-width: 1024px) {
      .post-body-wrap { grid-template-columns: 1fr; gap: 40px; padding: 30px 30px 60px; }
      .post-sidebar { position: static; }
      .post-title-section { padding: 10px 30px 30px; }
      .post-breadcrumb { padding: 20px 30px 10px; }
    }
    @media (max-width: 600px) {
      .post-body-wrap { padding: 20px 16px 50px; }
      .post-title-section { padding: 10px 16px 20px; max-width: 100%; }
      .post-breadcrumb { padding: 16px 16px 8px; }
      .post-title-section h1 { font-size: 26px; }
      .post-cta-banner { flex-direction: column; padding: 24px; }
      .post-cta-banner-img { width: 100%; height: 160px; }
    }
  </style>

  <main class="post-page" id="main-content">

    <!-- Breadcrumb -->
    <div class="post-breadcrumb">
      <a href="/">Home</a>
      <span>›</span>
      <a href="/blog">Blog</a>
      <span>›</span>
      <span set:html={title}></span>
    </div>

    <!-- Title -->
    <div class="post-title-section">
      <h1 set:html={title}></h1>
    </div>

    <!-- Body -->
    <div class="post-body-wrap">

      <!-- Article -->
      <article class="post-article">

        <!-- Featured image -->
        {img && (
          <img class="post-featured-img" src={img} alt={imgAlt} width="1200" height="500" loading="eager" />
        )}

        <!-- Meta -->
        <div class="post-meta">
          {author && (
            <span class="post-meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              {author}
            </span>
          )}
          <span class="post-meta-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {date}
          </span>
          {cats.map((cat: any) => (
            <a class="post-cat-tag" href={`/category/${cat.slug}`}>{cat.name}</a>
          ))}
        </div>

        <!-- Content -->
        <div class="post-content-body" set:html={content}></div>

        <!-- CTA Banner -->
        <div class="post-cta-banner">
          <img
            class="post-cta-banner-img"
            src="https://demskigroup.com/wp-content/uploads/2024/06/programmers-developing-software-in-team-2023-11-27-05-25-31-utc-1024x683.jpg"
            alt="Let's Talk About Custom Software"
            loading="lazy"
          />
          <div class="post-cta-text">
            <p>Let's Talk About How Custom Software Can Scale Your Business</p>
            <a href="/contact-us/">
              Schedule a Consultation
              <svg width="14" height="12" viewBox="0 0 14 12" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M0 6C0 5.77 0.09 5.55 0.25 5.39C0.41 5.23 0.63 5.14 0.86 5.14H10.79L7.11 1.46C6.95 1.3 6.85 1.09 6.85 0.86C6.85 0.63 6.95 0.41 7.11 0.25C7.27 0.09 7.48 0 7.71 0C7.94 0 8.16 0.09 8.32 0.25L13.46 5.39C13.54 5.47 13.6 5.57 13.65 5.67C13.69 5.78 13.71 5.89 13.71 6C13.71 6.11 13.69 6.22 13.65 6.33C13.6 6.43 13.54 6.53 13.46 6.61L8.32 11.75C8.16 11.91 7.94 12 7.71 12C7.48 12 7.27 11.91 7.11 11.75C6.95 11.59 6.85 11.37 6.85 11.14C6.85 10.91 6.95 10.7 7.11 10.54L10.79 6.86H0.86C0.63 6.86 0.41 6.77 0.25 6.61C0.09 6.45 0 6.23 0 6Z" fill="white"/></svg>
            </a>
          </div>
        </div>

        <!-- Post footer -->
        <div class="post-footer">
          <a class="post-back-link" href="/blog">
            ← Back to Blog
          </a>
        </div>

      </article>

      <!-- Sidebar -->
      <aside class="post-sidebar">

        <!-- Search -->
        <div class="sb-box">
          <form class="sb-search" action="/blog" method="get">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
            <input type="search" name="s" placeholder="Search..." />
          </form>
        </div>

        <!-- Recent Posts -->
        <div class="sb-box">
          <h3>Recent Posts</h3>
          <ul class="sb-recent-list">
            {recentPosts.map((p: any) => (
              <li>
                <a href={`/blog/${p.slug}`} set:html={p.title?.rendered}></a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Search 2 -->
        <div class="sb-box">
          <form class="sb-search" action="/blog" method="get">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/></svg>
            <input type="search" name="s" placeholder="Type to search..." />
          </form>
        </div>

        <!-- Categories -->
        <div class="sb-box">
          <h3>Blog Categories</h3>
          <ul class="sb-cat-list">
            {categories.filter((c: any) => c.count > 0).map((cat: any) => (
              <li>
                <a href={`/category/${cat.slug}`}>{cat.name}</a>
                <span>({cat.count})</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Technologies Tag Cloud -->
        <div class="sb-box">
          <h3>Technologies</h3>
          <div class="sb-tag-cloud">
            {tags.map((tag: any) => (
              <a href={`/technology/${tag.slug}/`} class="sb-tag">{tag.name}</a>
            ))}
          </div>
        </div>

      </aside>

    </div>
  </main>

</Layout>